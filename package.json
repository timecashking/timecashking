{
	"name": "timecashking-backend",
	"version": "1.0.0",
	"description": "Backend API para TimeCash King - Sistema de controle financeiro",
	"main": "server.js",
	"scripts": {
		"start": "node server.js",
		"dev": "nodemon server.js",
		"build": "echo 'No build step required'",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --watchAll=false",
		"lint": "eslint server.js --ext .js,.ts",
		"lint:fix": "eslint server.js --ext .js,.ts --fix",
		"format": "prettier --write \"server.js\"",
		"format:check": "prettier --check \"server.js\"",
		"type-check": "tsc --noEmit",
		"prepare": "husky install"
	},
	"keywords": [
		"finance",
		"api",
		"nodejs",
		"express",
		"prisma",
		"postgresql",
		"telegram",
		"google-calendar",
		"inventory",
		"sales"
	],
	"author": "TimeCash King Team",
	"license": "MIT",
	"dependencies": {
		"@prisma/client": "^5.7.1",
		"express": "^4.18.2",
		"cors": "^2.8.5",
		"helmet": "^7.1.0",
		"dotenv": "^16.3.1",
		"jsonwebtoken": "^9.0.2",
		"bcryptjs": "^2.4.3",
		"stripe": "^14.10.0",
		"nodemailer": "^6.9.7",
		"web-push": "^3.6.6",
		"axios": "^1.6.2",
		"express-rate-limit": "^7.1.5",
		"express-validator": "^7.0.1",
		"compression": "^1.7.4",
		"morgan": "^1.10.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.0",
		"telegraf": "^4.15.6",
		"googleapis": "^128.0.0",
		"node-cron": "^3.0.3",
		"google-auth-library": "^9.4.1"
	},
	"devDependencies": {
		"prisma": "^5.7.1",
		"nodemon": "^3.0.2",
		"jest": "^29.7.0",
		"supertest": "^6.3.3",
		"@types/jest": "^29.5.8",
		"@types/node": "^20.10.4",
		"@types/express": "^4.17.21",
		"@types/cors": "^2.8.17",
		"@types/bcryptjs": "^2.4.6",
		"@types/jsonwebtoken": "^9.0.5",
		"@types/compression": "^1.7.5",
		"@types/morgan": "^1.9.9",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.6",
		"@types/node-cron": "^3.0.11",
		"eslint": "^8.55.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.0.1",
		"@typescript-eslint/eslint-plugin": "^6.13.1",
		"@typescript-eslint/parser": "^6.13.1",
		"prettier": "^3.1.1",
		"husky": "^8.0.3",
		"lint-staged": "^15.2.0",
		"typescript": "^5.3.3"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"jest": {
		"testEnvironment": "node",
		"collectCoverageFrom": [
			"server.js",
			"!**/*.test.{js,ts}",
			"!**/*.spec.{js,ts}"
		],
		"coverageThreshold": {
			"global": {
				"branches": 80,
				"functions": 80,
				"lines": 80,
				"statements": 80
			}
		}
	},
	"engines": {
		"node": ">=18.0.0",
		"npm": ">=8.0.0"
	}
}
