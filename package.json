{
	"name": "timecashking-backend",
	"version": "1.0.0",
	"type": "module",
	"description": "Backend API para TimeCash King - Sistema de controle financeiro",
	"main": "server.js",
	"scripts": {
		"start": "node server.js",
		"dev": "nodemon server.js",
		"dev:local": "node scripts/generate-prisma-local.cjs && nodemon server.js",
		"build": "echo 'No build step required'",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --watchAll=false",
		"lint": "eslint server.js --ext .js,.ts",
		"lint:fix": "eslint server.js --ext .js,.ts --fix",
		"format": "prettier --write \"server.js\"",
		"format:check": "prettier --check \"server.js\"",
		"prepare": "husky install",
		"prisma:generate": "npx prisma generate",
		"prisma:generate:local": "node scripts/generate-prisma-local.cjs",
		"setup:admin": "node scripts/setup-admin.js"
	},
	"keywords": [
		"finance",
		"api",
		"nodejs",
		"express",
		"prisma",
		"postgresql",
		"telegram",
		"google-calendar",
		"inventory",
		"sales"
	],
	"author": "TimeCash King Team",
	"license": "MIT",
	"dependencies": {
		"@prisma/client": "^5.7.1",
		"express": "^4.18.2",
		"cors": "^2.8.5",
		"helmet": "^7.1.0",
		"dotenv": "^16.3.1",
		"jsonwebtoken": "^9.0.2",
		"bcryptjs": "^2.4.3",
		"stripe": "^14.10.0",
		"nodemailer": "^6.9.7",
		"web-push": "^3.6.6",
		"axios": "^1.6.2",
		"express-rate-limit": "^7.1.5",
		"express-validator": "^7.0.1",
		"compression": "^1.7.4",
		"morgan": "^1.10.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.0",
		"telegraf": "^4.15.6",
		"googleapis": "^128.0.0",
		"node-cron": "^3.0.3",
		"google-auth-library": "^9.4.1"
	},
	"devDependencies": {
		"prisma": "^5.7.1",
		"nodemon": "^3.0.2",
		"jest": "^29.7.0",
		"supertest": "^6.3.3",

		"eslint": "^8.55.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.0.1",
		"prettier": "^3.1.1",
		"husky": "^8.0.3"
	},
	"engines": {
		"node": ">=18.0.0",
		"npm": ">=8.0.0"
	}
}
