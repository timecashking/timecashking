// Prisma schema for TimeCash King - Local Development
// datasource
datasource db {
	provider = "sqlite"
	url      = "file:./dev.db"
}

generator client {
	provider = "prisma-client-js"
}

// ===== MODELS =====

// Usuários
model User {
	id             String   @id @default(cuid())
	googleId       String?  @unique // Opcional agora
	email          String   @unique
	password       String?  // Hash da senha
	salt           String?  // Salt para hash
	name           String?
	avatarUrl      String?
	createdAt      DateTime @default(now())
	updatedAt      DateTime @updatedAt

	// Relations
	companyUsers CompanyUser[]
}

// Empresas
model Company {
	id          String   @id @default(cuid())
	name        String
	description String?
	cnpj        String?  // Não obrigatório
	address     String?
	phone       String?
	email       String?
	website     String?
	logo        String?
	status      String   @default("ACTIVE") // "ACTIVE" ou "INACTIVE"
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt

	// Relations
	companyUsers CompanyUser[]
	accounts     Account[]
	categories  Category[]
	transactions Transaction[]
	bills        Bill[]
	creditCardInvoices CreditCardInvoice[]
	creditCardPayments CreditCardPayment[]
	products    Product[]
	movements   StockMovement[]
	salesOrders SalesOrder[]
	purchaseOrders PurchaseOrder[]
	events      Event[]
	notifications Notification[]
	activationCodes ActivationCode[]
}

// Usuários da Empresa
model CompanyUser {
	id        String   @id @default(cuid())
	companyId String
	company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	userId    String
	user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
	role      String  @default("MEMBER") // "OWNER", "ADMIN", "MEMBER"
	createdAt DateTime @default(now())

	@@unique([companyId, userId])
}

// Contas
model Account {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	name        String
	type        String  @default("BANK") // "CASH", "BANK", "CREDIT_CARD"
	balance     Float   @default(0)
	currency    String  @default("BRL")
	description String?
	status      String  @default("ACTIVE") // "ACTIVE" ou "INACTIVE"
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt

	// Relations
	transactions Transaction[]
	bills        Bill[]
	creditCardInvoices CreditCardInvoice[]
}

// Categorias
model Category {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	name        String
	type        String  @default("EXPENSE") // "INCOME", "EXPENSE", "TRANSFER"
	description String?
	color       String?
	icon        String?
	parentId    String?
	parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
	children    Category[] @relation("CategoryHierarchy")
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt

	// Relations
	transactions Transaction[]
}

// Transações
model Transaction {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	accountId   String
	account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
	categoryId  String?
	category    Category? @relation(fields: [categoryId], references: [id])
	description String
	amount      Float
	type        String  @default("EXPENSE") // "INCOME", "EXPENSE", "TRANSFER"
	date        DateTime
	recurrence  String?          // "monthly", "weekly", etc.
	notes       String?          // Notas adicionais
	creditCardInvoiceId String?  // Fatura de cartão associada
	creditCardInvoice CreditCardInvoice? @relation(fields: [creditCardInvoiceId], references: [id])
	createdAt   DateTime         @default(now())
	updatedAt   DateTime         @updatedAt
}

// Contas a Pagar/Receber
model Bill {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	accountId   String
	account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
	description String
	amount      Float
	type        String  @default("PAYABLE") // "PAYABLE" ou "RECEIVABLE"
	status      String  @default("PENDING") // "PENDING", "PAID", "OVERDUE"
	dueDate     DateTime
	paidAt      DateTime?
	notes       String?
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt
}

// Faturas de Cartão de Crédito
model CreditCardInvoice {
	id              String      @id @default(cuid())
	companyId       String
	company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
	accountId       String
	account         Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
	billingMonth    Int         // Mês da fatura (1-12)
	billingYear     Int         // Ano da fatura
	billingDay      Int         // Dia do fechamento
	dueDate         DateTime    // Data de vencimento
	totalAmount     Float       @default(0)
	totalTransactions Int       @default(0)
	status          String      @default("OPEN") // "OPEN", "CLOSED", "PAID", "CANCELLED"
	closedAt        DateTime?   // Quando foi fechada
	paidAt          DateTime?   // Quando foi paga
	cancelledAt     DateTime?   // Quando foi cancelada
	cancellationReason String?  // Motivo do cancelamento
	createdAt       DateTime    @default(now())
	updatedAt       DateTime    @updatedAt

	// Relations
	transactions    Transaction[]
	payment        CreditCardPayment?

	@@unique([companyId, accountId, billingMonth, billingYear])
}

// Pagamentos de Faturas de Cartão
model CreditCardPayment {
	id            String        @id @default(cuid())
	companyId     String
	company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
	invoiceId     String        @unique
	invoice       CreditCardInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
	paymentDate   DateTime
	paymentMethod String        // "CASH", "PIX", "CREDIT_CARD", "DEBIT_CARD", "BANK_TRANSFER"
	paymentAmount Float
	notes         String?
	createdAt     DateTime      @default(now())
}

// Produtos
model Product {
	id            String   @id @default(cuid())
	companyId     String
	company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	sku           String   @unique
	name          String
	description   String?
	cost          Float
	salePrice     Float
	stock         Int      @default(0)
	minStock      Int      @default(0)
	category      String?
	status        String   @default("ACTIVE") // "ACTIVE" ou "INACTIVE"
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	// Relations
	movements     StockMovement[]
	salesItems    SalesOrderItem[]
	purchaseItems PurchaseOrderItem[]
}

// Movimentações de estoque
model StockMovement {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	productId   String
	product     Product @relation(fields: [productId], references: [id])
	type        String   // "ENTRY" ou "EXIT"
	reason      String   // "PURCHASE", "SALE", "RETURN", "DONATION", "LOSS", "ADJUSTMENT"
	quantity    Int
	unitCost    Float
	totalCost   Float
	description String?
	date        DateTime @default(now())
	createdAt   DateTime @default(now())
}

// Pedidos de venda
model SalesOrder {
	id            String   @id @default(cuid())
	companyId     String
	company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	customerName  String
	customerEmail String?
	customerPhone String?
	status        String   @default("DRAFT") // "DRAFT", "CONFIRMED", "CANCELLED", "DELIVERED"
	total         Float    @default(0)
	discount      Float    @default(0)
	paymentMethod String   // "CASH", "PIX", "CREDIT_CARD", "DEBIT_CARD", "BANK_TRANSFER"
	notes         String?
	orderDate     DateTime @default(now())
	deliveryDate  DateTime?
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	// Relations
	items         SalesOrderItem[]
}

// Itens do pedido de venda
model SalesOrderItem {
	id           String      @id @default(cuid())
	salesOrderId String
	salesOrder   SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
	productId    String
	product      Product     @relation(fields: [productId], references: [id])
	quantity     Int
	unitPrice    Float
	totalPrice   Float
	discount     Float       @default(0)
	createdAt    DateTime    @default(now())
}

// Pedidos de compra
model PurchaseOrder {
	id            String   @id @default(cuid())
	companyId     String
	company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	supplierName  String
	supplierEmail String?
	supplierPhone String?
	status        String   @default("DRAFT") // "DRAFT", "CONFIRMED", "CANCELLED", "DELIVERED"
	total         Float    @default(0)
	discount      Float    @default(0)
	paymentMethod String   // "CASH", "PIX", "CREDIT_CARD", "DEBIT_CARD", "BANK_TRANSFER"
	notes         String?
	orderDate     DateTime @default(now())
	deliveryDate  DateTime?
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	// Relations
	items         PurchaseOrderItem[]
}

// Itens do pedido de compra
model PurchaseOrderItem {
	id             String        @id @default(cuid())
	purchaseOrderId String
	purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
	productId      String
	product        Product       @relation(fields: [productId], references: [id])
	quantity       Int
	unitCost       Float
	totalCost      Float
	discount       Float         @default(0)
	createdAt      DateTime      @default(now())
}

// Eventos/Agenda
model Event {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	title       String
	description String?
	type        String   @default("MEETING") // "MEETING", "APPOINTMENT", "REMINDER", "OTHER"
	startDate   DateTime
	endDate     DateTime
	location    String?
	attendees   String?
	notes       String?
	googleEventId String?
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt
}

// Notificações
model Notification {
	id           String   @id @default(cuid())
	companyId    String
	company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	userId       String
	title        String
	message      String
	type         String   @default("EMAIL") // "EMAIL", "PUSH", "TELEGRAM", "BOTH"
	category     String   @default("REMINDER") // "REMINDER", "ALERT", "REPORT", "PAYMENT", "SYSTEM", "STOCK", "EVENT"
	status       String   @default("PENDING") // "PENDING", "SENT", "FAILED", "READ"
	sentAt       DateTime?
	readAt       DateTime?
	createdAt    DateTime @default(now())
	updatedAt    DateTime @updatedAt
}

// Códigos de Ativação
model ActivationCode {
	id          String   @id @default(cuid())
	companyId   String
	company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
	code        String   @unique
	expiresAt   DateTime
	isUsed      Boolean  @default(false)
	createdAt   DateTime @default(now())
}
